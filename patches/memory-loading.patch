+            const char * name = gguf_get_tensor_name(ctx_gguf, i);
+            struct gguf_tensor_info * info = (struct gguf_tensor_info *) gguf_get_tensor_info(ctx_gguf, i);
+            tensors_map.emplace(name, llama_tensor_info{(uint32_t)i, info->ne, info->n_dims, info->type, info->offset});
+        }
+
+        // Calculate total size
+        size_data = 0;
+        for (int i = 0; i < n_tensors; i++) {
+            struct gguf_tensor_info * info = (struct gguf_tensor_info *) gguf_get_tensor_info(ctx_gguf, i);
+            size_data += ggml_nbytes_pad(ggml_row_size(info->type, info->ne[0]), info->ne[1]) * info->ne[2] * info->ne[3];
+        }
+
+        // Store buffer data
+        this->buffer_data = buffer;
+        this->buffer_size = buffer_size;
+        this->use_mmap = false;  // Always false for memory buffers
+        
+        // Find data offset in buffer
+        size_t meta_size = gguf_get_meta_size(ctx_gguf);
+        size_t data_offset = GGUF_HEADER_SIZE + meta_size;
+        data_offset = (data_offset + ctx_gguf->alignment - 1) & ~(ctx_gguf->alignment - 1);
+        
+        if (data_offset + size_data > buffer_size) {
+            throw std::runtime_error("buffer too small for model data");
