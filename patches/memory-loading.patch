+    // Modified load_data_for to handle memory buffers
+    size_t load_data_for(struct ggml_tensor * cur) const {
+        if (buffer_data != nullptr) {
+            // Load from memory buffer
+            const auto & info = tensors_map.at(ggml_get_name(cur));
+            
+            // Find data offset in buffer
+            size_t meta_size = gguf_get_meta_size(ctx_gguf);
+            size_t data_offset = GGUF_HEADER_SIZE + meta_size;
+            data_offset = (data_offset + ctx_gguf->alignment - 1) & ~(ctx_gguf->alignment - 1);
+            
+            size_t tensor_offset = data_offset + info.offset;
+            size_t tensor_size = ggml_nbytes(cur);
+            
+            if (tensor_offset + tensor_size > buffer_size) {
+                throw std::runtime_error("tensor data out of bounds");
+            }
+            
+            memcpy(cur->data, (const char *)buffer_data + tensor_offset, tensor_size);
