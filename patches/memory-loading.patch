+struct llama_model * llama_load_model_from_buffer(
+        const void * buffer,
+        size_t buffer_size,
+        struct llama_context_params params) {
+    
+    llama_model * model = new llama_model;
+
+    ggml_time_init();
+    unsigned t_start_us = ggml_time_us();
+
+    try {
+        llama_model_loader ml(buffer, buffer_size, params.use_mmap);
+
+        model->hparams.vocab_only = params.vocab_only;
+
+        llm_load_arch   (ml, *model);
+        llm_load_hparams(ml, *model, params.n_gpu_layers, params.main_gpu, params.tensor_split);
+        llm_load_vocab  (ml, *model);
+        llm_load_print_meta(ml, *model);
+        llm_load_tensors(ml, *model, params.n_gpu_layers, params.main_gpu, params.tensor_split, params.mul_mat_q, params.low_vram, params.use_mlock, params.progress_callback, params.progress_callback_user_data);
+    } catch (const std::exception & err) {
+        LLAMA_LOG_ERROR("error loading model from buffer: %s\n", err.what());
+        delete model;
+        return nullptr;
+    }
+
+    unsigned t_end_us = ggml_time_us();
+    model->t_load_us = t_end_us - t_start_us;
+
+    return model;
+}
